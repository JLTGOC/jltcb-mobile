{
  "expo": {
    "name": "JLTCB",
    "slug": "JLTCB",
    "version": "1.0.0",
    "newArchEnabled": true,
     "android": {
      "package": "com.jltcb.app",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/appImage.png",
        "backgroundColor": "#E6F4FE"
      },
       "newArchEnabled": true,
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-video",
      "expo-web-browser",
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo-google-fonts/martel-sans/900Black/MartelSans_900Black.ttf",
            "node_modules/@expo-google-fonts/martel-sans/800ExtraBold/MartelSans_800ExtraBold.ttf"
          ]
        }
      ],
      "expo-secure-store",
      [
        "expo-asset",
        { "assets": ["./src/assets/dashboard-folder-icons"] }
      ],
      [
        "expo-build-properties",
        { "android": { "usesCleartextTraffic": true } }
      ] 
    ],
    "extra": {
      "eas": {
        "projectId": "9fefdb2d-73c6-4835-8885-b24480e2abe2"
      }
    }
  }
}